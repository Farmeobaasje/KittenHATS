# Force LF line endings for KittenHATS source files.
# Prevents CRLF conversion on Windows checkout.
# NOTE: app/vendor/hekate/ is a submodule — do NOT add rules here that affect it.
*.c text eol=lf
*.h text eol=lf
*.md text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.ld text eol=lf
*.S text eol=lf
Makefile text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.gitignore text eol=lf
*.gitmodules text eol=lf
*.gitattributes text eol=lf
